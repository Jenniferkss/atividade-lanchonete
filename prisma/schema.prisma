generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

enum Categoria {
    LANCHE
    BEBIDA
    SOBREMESA
    COMBO
}

model Produto {
    id         Int       @id @default(autoincrement())
    nome       String
    descricao  String?
    categoria  Categoria
    preco      Decimal   @db.Decimal(10, 2)
    disponivel Boolean   @default(true)
    createdAt  DateTime  @default(now())
    update     DateTime  @updatedAt

    @@map("produtos")
}

model itemPedido {
    id         Int     @id @default(autoincrement())
    produtoId  Int
    quantidade Int
    preco      Decimal @db.Decimal(10, 2)
    pedidoId   Int

    @@map("itens_pedido")
}

model Cliente {
    id         Int     @id @default(autoincrement())
    nome       String  @db.VarChar(100)
    telefone   String?
    email      String? @unique
    cpf        String? @unique
    cep        String?
    logradouro String?
    bairro     String?
    localidade String?
    uf         String?
    ativo      Boolean @default(true)

    @@map("clientes")
}
